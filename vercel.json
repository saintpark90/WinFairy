{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm ci",
  "rewrites": [{ "source": "/((?!assets/).*)", "destination": "/index.html" }],
  "build": {
    "env": {
      "VITE_BASE_PATH": "/"
    }
  }
}
